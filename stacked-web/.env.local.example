# Supabase — mesmo projeto do app Flutter (lib/main.dart)
NEXT_PUBLIC_SUPABASE_URL=https://gbpoenvogrcqhcqfjldd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role — só no servidor (API routes Google Calendar). Nunca exponha no client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Calendar OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Origem pública do site (redirect OAuth). Dev: omita ou use http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Copie a publishableKey de lib/main.dart para NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# Google Calendar — no Google Cloud, OAuth client "Web application":
#   Authorized redirect URI: {NEXT_PUBLIC_SITE_URL}/api/google/calendar/callback
#   Ex.: http://localhost:3000/api/google/calendar/callback
#        https://get-stacked-app.netlify.app/api/google/calendar/callback
#
# Supabase: rode a migration supabase/migrations/20260704120000_google_calendar_connections.sql
#
# Produção (Netlify): adicione as mesmas variáveis em
# Site configuration → Environment variables
# e configure no Supabase → Authentication → URL Configuration:
#   Site URL: https://get-stacked-app.netlify.app
#   Redirect URLs: https://get-stacked-app.netlify.app/auth/callback
