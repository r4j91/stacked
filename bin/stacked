#!/usr/bin/env bash
# Stacked CLI — atalhos locais do monorepo.
# Uso: stacked ios | stacked web
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'EOF'
Stacked — atalhos de desenvolvimento

  stacked ios
      Bootstrap + abre stacked-ios no Xcode.

  stacked web
      Inicia stacked-web (npm run dev).

  stacked -h | --help
      Mostra esta ajuda.
EOF
}

open_ios() {
  cd "$ROOT/stacked-ios"
  ./scripts/bootstrap.sh
  open Stacked.xcodeproj
}

run_web() {
  cd "$ROOT/stacked-web"
  exec npm run dev
}

case "${1:-}" in
  ios|-ios)
    open_ios
    ;;
  web|-web)
    run_web
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "Opção desconhecida: $1" >&2
    echo >&2
    usage >&2
    exit 1
    ;;
esac
